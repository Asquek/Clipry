{
  "name": "clipry",
  "version": "1.0.1",
  "main": "electron.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-updater": "^6.8.9",
    "fluent-ffmpeg": "^2.1.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.clipry.app",
    "productName": "Clipry",
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/@ffmpeg-installer/win32-x64/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "drag-icon-dummy.png",
        "to": "drag-icon-dummy.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Asquek",
      "repo": "Clipry"
    },
    "win": {
      "target": "nsis",
      "signingHashAlgorithms": [],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "electron@28.3.3": true,
    "esbuild@0.21.5": true,
    "electron-updater@6.8.9": true
  }
}
